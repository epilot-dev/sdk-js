{
  "openapi": "3.0.3",
  "info": {
    "title": "Configuration Hub API",
    "description": "API for exploring epilot organization configurations.\nProvides a unified tree index across all config types (journeys, automations, schemas, etc.)\nand resolves dependencies between configs.\n",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://configuration-hub.dev.sls.epilot.io",
      "description": "Dev"
    },
    {
      "url": "https://configuration-hub.sls.epilot.io",
      "description": "Production"
    }
  ],
  "security": [
    {
      "EpilotAuth": []
    }
  ],
  "tags": [
    {
      "name": "Configs",
      "description": "Configuration tree index"
    }
  ],
  "paths": {
    "/v1/configs/types": {
      "get": {
        "operationId": "listConfigTypes",
        "summary": "listConfigTypes",
        "description": "List all available configuration types with item counts.\nUsed to render the top-level folders in the config tree.\n",
        "tags": [
          "Configs"
        ],
        "responses": {
          "200": {
            "description": "List of config types with counts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ConfigTypeInfo"
                      }
                    }
                  },
                  "required": [
                    "results"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/configs/{type}": {
      "get": {
        "operationId": "listConfigs",
        "summary": "listConfigs",
        "description": "List all configs of a given type. Returns summary metadata only (not full payloads).\nUsed to render items under a type folder in the config tree.\n",
        "tags": [
          "Configs"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ConfigType"
          }
        ],
        "responses": {
          "200": {
            "description": "Config index for the given type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid config type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/configs/{type}/{id}/dependencies": {
      "get": {
        "operationId": "getConfigDependencies",
        "summary": "getConfigDependencies",
        "description": "Get configs that are referenced by the given config.\nUsed to render children when expanding a config node in the tree.\nResolves dependencies by scanning the config payload for references.\n",
        "tags": [
          "Configs"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ConfigType"
          },
          {
            "$ref": "#/components/parameters/ConfigId"
          }
        ],
        "responses": {
          "200": {
            "description": "List of referenced configs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ConfigNode"
                      }
                    }
                  },
                  "required": [
                    "results"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Config not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "EpilotAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "epilot JWT auth token"
      }
    },
    "parameters": {
      "ConfigType": {
        "name": "type",
        "in": "path",
        "required": true,
        "description": "Configuration resource type",
        "schema": {
          "$ref": "#/components/schemas/ResourceType"
        }
      },
      "ConfigId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Configuration resource ID",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "ResourceType": {
        "type": "string",
        "description": "Configuration resource type identifier. Matches blueprint-manifest-api V3 naming.",
        "enum": [
          "journey",
          "automation_flow",
          "workflow_definition",
          "closing_reason",
          "flow_template",
          "schema",
          "emailtemplate",
          "product",
          "price",
          "tax",
          "coupon",
          "file",
          "webhook",
          "saved_view",
          "dashboard",
          "kanban",
          "role",
          "usergroup",
          "validation_rule",
          "integration",
          "app",
          "designbuilder",
          "notification_template",
          "custom_variable",
          "environment_variable",
          "taxonomy",
          "taxonomy_classification",
          "entity_mapping",
          "portal_config",
          "target",
          "product_recommendation"
        ]
      },
      "ConfigTypeInfo": {
        "type": "object",
        "description": "Summary info for a config type folder in the tree",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ResourceType"
          },
          "label": {
            "type": "string",
            "description": "Display label",
            "example": "Journeys"
          },
          "icon": {
            "type": "string",
            "description": "Frontend icon name",
            "example": "Route"
          },
          "count": {
            "type": "integer",
            "description": "Number of configs of this type",
            "example": 8
          }
        },
        "required": [
          "type",
          "label",
          "icon",
          "count"
        ]
      },
      "ConfigNode": {
        "type": "object",
        "description": "Summary metadata for a single configuration item in the tree",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ResourceType"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier"
          },
          "title": {
            "type": "string",
            "description": "Display name"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last modified timestamp"
          },
          "updated_by": {
            "type": "string",
            "description": "User who last modified this config"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags / labels"
          },
          "purposes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Business purposes"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Direct link to open this config in epilot"
          }
        },
        "required": [
          "type",
          "id",
          "title"
        ]
      },
      "ConfigListResponse": {
        "type": "object",
        "description": "List of configs for a specific type",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ResourceType"
          },
          "label": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConfigNode"
            }
          }
        },
        "required": [
          "type",
          "label",
          "icon",
          "count",
          "items"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "error"
        ]
      }
    }
  }
}