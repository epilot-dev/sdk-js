          "Kanban"
        ],
        "parameters": [
          {
            "name": "boardId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the board to set as default",
            "example": "board-abc123"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully set default board",
