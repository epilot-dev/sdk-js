    "jsonata": "^2.0.0",
    "mock-json-schema": "^1.1.2",
    "open": "^10.0.0",
    "openapi-client-axios": "^7.8.0"
  },
  "devDependencies": {
    "msw": "^2.12.10",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
