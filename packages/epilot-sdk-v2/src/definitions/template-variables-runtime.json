    ["createCustomVariable", "post", "/v1/custom-variables", null, 1],
    ["searchCustomVariables", "post", "/v1/custom-variables:search", null, 1],
    ["updateCustomVariable", "put", "/v1/custom-variables/{id}", [["id", "p", true]], 1],
    ["getCustomVariable", "get", "/v1/custom-variables/{id}", [["id", "p", true]]],
